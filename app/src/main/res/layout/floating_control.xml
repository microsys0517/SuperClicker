<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#DD222222"
    android:padding="8dp"
    android:minWidth="200dp">

    <LinearLayout
        android:id="@+id/layout_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_floating_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="就绪"
            android:textColor="#FF4CAF50"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_floating_step"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_floating_loop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btn_floating_play"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="播放" />

        <ImageButton
            android:id="@+id/btn_floating_pause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_pause"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="暂停" />

        <ImageButton
            android:id="@+id/btn_floating_stop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_ff"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="停止" />

        <ImageButton
            android:id="@+id/btn_floating_hide"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_view"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="隐藏" />

        <ImageButton
            android:id="@+id/btn_floating_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="关闭" />
    </LinearLayout>

</LinearLayout>
