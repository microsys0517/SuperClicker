        StringBuilder wait = new StringBuilder();
        if (step.waitBefore > 0) wait.append("فë").append(step.waitBefore).append("ms ");
        if (step.waitAfter > 0) wait.append("ف").append(step.waitAfter).append("ms ");
        if (step.retryCount > 0) wait.append("لçك»ـ").append(step.retryCount).append("µشة ");
        holder.tvWait.setText(wait.toString().trim());

        holder.switchEnabled.setOnCheckedChangeListener(null);
        holder.switchEnabled.setChecked(step.enabled);
        holder.switchEnabled.setOnCheckedChangeListener(new CompoundButton.OnCheckedChangeListener() {
            @Override
            public void onCheckedChanged(CompoundButton buttonView, boolean isChecked) {
                step.enabled = isChecked;
            }
        });

        if (selectionMode) {
            holder.cbSelect.setVisibility(View.VISIBLE);
        } else {
            holder.cbSelect.setVisibility(View.GONE);
        }
        holder.cbSelect.setOnCheckedChangeListener(null);
        holder.cbSelect.setChecked(selectedIds.contains(step.id));
        holder.cbSelect.setOnCheckedChangeListener(new CompoundButton.OnCheckedChangeListener() {
            @Override
            public void onCheckedChanged(CompoundButton buttonView, boolean isChecked) {
                if (isChecked) {
                    selectedIds.add(step.id);
                } else {
                    selectedIds.remove(step.id);
                }
            }
        });

        holder.itemView.setOnClickListener(v -> {
            if (selectionMode) {
                if (selectedIds.contains(step.id)) {
                    selectedIds.remove(step.id);
                } else {
                    selectedIds.add(step.id);
                }
                notifyItemChanged(position);
            } else {
                listener.onClick(step);
            }
        });

        holder.itemView.setOnLongClickListener(v -> {
            selectionMode = true;
            selectedIds.add(step.id);
            notifyDataSetChanged();
            return true;
        });
    }

