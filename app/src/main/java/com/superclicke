    private String getStepDetail(Step step) {
        switch (step.type) {
            case CLICK:
                return "(" + step.x1 + ", " + step.y1 + ")";
            case SWIPE:
                return "(" + step.x1 + "," + step.y1 + ")->(" + step.x2 + "," + step.y2 + ")";
            case LONG_PRESS:
                return "(" + step.x1 + ", " + step.y1 + ") " + step.duration + "ms";
